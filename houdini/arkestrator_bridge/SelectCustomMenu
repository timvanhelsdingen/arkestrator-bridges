# }
#
# Includes Houdini defaults and an Arkestrator helper action so component
# selection workflows can add context without switching panes.

"3D Connected Geometry"
{
pane = kwargs['pane']
if isinstance(pane, hou.ContextViewer):
    pane = pane.sceneViewer()
pane.setGroupPicking(True)
pane.setGroupListMask('+3d')
}

"UV Connected Geometry"
{
pane = kwargs['pane']
if isinstance(pane, hou.ContextViewer):
    pane = pane.sceneViewer()
pane.setGroupPicking(True)
pane.setGroupListMask('+uv')
}

"Geometry Groups"
{
pane = kwargs['pane']
if isinstance(pane, hou.ContextViewer):
    pane = pane.sceneViewer()
pane.setGroupPicking(True)
pane.setGroupListMask('*')
}

"Cut Geometry for UV Layout"
{
pane = kwargs['pane']
if isinstance(pane, hou.ContextViewer):
    pane = pane.sceneViewer()
pane.setGroupListVisible(True)
pane.setGroupPicking(False)
pane.setGroupListMask('+cut')
pane.setPickModifier(hou.pickModifier.Add)
pane.setPickGeometryType(hou.geometryType.Edges)
}

"Alembic Paths"
{
pane = kwargs['pane']
if isinstance(pane, hou.ContextViewer):
    pane = pane.sceneViewer()
pane.setGroupPicking(True)
pane.setGroupListMask('@path *')
pane.setPickGeometryType(hou.geometryType.Primitives)
}

"Name Attribute"
{
pane = kwargs['pane']
if isinstance(pane, hou.ContextViewer):
    pane = pane.sceneViewer()
pane.setGroupPicking(True)
pane.setGroupListMask('@name *')
# If the current geo type is points stay in it and don't change to primitives
# See bug 126350
if pane.pickGeometryType() != hou.geometryType.Points:
    pane.setPickGeometryType(hou.geometryType.Primitives)
}

